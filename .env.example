# Zoom MCP — Configuração de Credenciais
# Copie este arquivo para .env e preencha com suas credenciais do Zoom Marketplace

# Client ID do seu app OAuth no Zoom Marketplace
ZOOM_CLIENT_ID=sua_client_id_aqui

# Client Secret do seu app OAuth no Zoom Marketplace
ZOOM_CLIENT_SECRET=sua_client_secret_aqui

# Redirect URI (não altere — deve ser igual ao configurado no Zoom Marketplace)
ZOOM_REDIRECT_URI=http://localhost:4488/callback
